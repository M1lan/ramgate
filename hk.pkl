amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

// ramgate git hooks (hk) -- a faithful port of the previous prek
// (.pre-commit-config.yaml) setup, plus the shared secret+PII scanner.
// Nothing from prek was dropped:
//   * stock hygiene (trailing ws, EOF, line endings, large files, merge marks)
//     -> hk builtins (same upstream logic, with auto-fixers)
//   * yaml/json/toml -> PARSE-VALIDITY only (yq/jq/taplo), matching prek's
//     check-yaml/json/toml -- deliberately NOT yamllint/jq-format (too strict)
//   * secrets -> scripts/ci/scan.bash (gitleaks dir + email-PII; replaces the
//     old staged-gitleaks hook that no-ops on git >= 2.55)
//   * format / shellcheck / bash -n / rumdl / commit-msg / branch-name ->
//     the existing scripts/hooks/*.bash, unchanged
//
// Activate:  hk install     (replaces the prek git-hook shims in .git/hooks)

// ── Stock hygiene: auto-fixers (faithful pre-commit-hooks equivalents) ────────
local hygiene = new Mapping<String, Step> {
  ["trailing-whitespace"] = (Builtins.trailing_whitespace) {
    exclude = Regex(#"\.md$"#)
  }
  ["end-of-file-fixer"] = Builtins.newlines
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["check-added-large-files"] = (Builtins.check_added_large_files) {
    check = "hk util check-added-large-files --maxkb 512 {{files}}"
  }
  // Parse-validity only -- matches prek's check-yaml/json/toml (NOT linting).
  ["check-yaml"] {
    glob = Regex(#"\.ya?ml$"#)
    check = "yq '.' {{files}} > /dev/null"
  }
  ["check-json"] {
    glob = Regex(#"\.json$"#)
    check = "jq empty {{files}}"
  }
  ["check-toml"] {
    glob = Regex(#"\.toml$"#)
    check = "taplo lint {{files}}"
  }
}

// ── Quality checks (mirror prek exactly, incl. extensionless bin/*) ───────────
local quality = new Mapping<String, Step> {
  ["shellcheck"] {
    glob = Regex(#"^(bin/[^/]+|lib/.*\.bash|test/.*\.bash|scripts/.*\.bash)$"#)
    check = #"bash -c 'command -v shellcheck >/dev/null 2>&1 && shellcheck -x "$@" || echo "shellcheck not installed -- skipping"' -- {{files}}"#
  }
  ["bash-syntax"] {
    glob = Regex(#"(\.bash$|^bin/[^/]+$)"#)
    check = #"bash -c 'err=0; for f in "$@"; do bash -n "$f" || err=1; done; exit $err' -- {{files}}"#
  }
  ["rumdl"] {
    glob = Regex(#"\.(md|markdown|mdown)$"#)
    check = "rumdl check"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ...hygiene
      // SAFETY: secrets + PII on the staged tree (blocks on hit).
      ["secrets-pii"] {
        check = "bash scripts/ci/scan.bash --staged"
      }
      // STYLE: shfmt + rumdl auto-format staged files and re-stage.
      ["format"] {
        glob = Regex(#"(\.bash$|\.md$|^bin/[^/]+$)"#)
        check = "scripts/hooks/pre-commit-format.bash {{files}}"
      }
      ...quality
    }
  }

  ["commit-msg"] {
    steps {
      ["conventional-commit"] {
        check = "scripts/hooks/commit-msg.bash {{commit_msg_file}}"
      }
    }
  }

  ["pre-push"] {
    steps {
      ["conventional-branch"] {
        check = "scripts/hooks/pre-push-branch.bash"
      }
    }
  }

  // `hk check` -- full-tree verification (non-mutating).
  ["check"] {
    steps {
      ...hygiene
      ["secrets-pii"] {
        check = "bash scripts/ci/scan.bash"
      }
      ...quality
    }
  }
}

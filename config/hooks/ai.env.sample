# AI-assist configuration for the git hooks + ai-* recipes -- written by `just hooks-ai-setup`.
# Copy to ai.env (gitignored) or just run the wizard. Local-first by design: a model on THIS
# machine is preferred; frontier coding CLIs are the last resort.
#
# The hooks pipe "<instruction>\n\n<payload>" to HOOKS_AI_CMD on stdin and read stdout. AI is
# ONLY ever invoked behind an explicit [a] choice, and only after the deterministic fixes run.
# Leave HOOKS_AI_CMD empty (or never run the wizard) to keep AI assist fully disabled.
#
# SECURITY: this file is `source`d by the hooks and HOOKS_AI_CMD is executed -- keep it
# trusted (the wizard writes values with printf %q). Do not paste untrusted content here.
#
# HOOKS_AI_CMD is always the backend wrapper; HOOKS_AI_BACKEND selects the engine:
HOOKS_AI_CMD=''
HOOKS_AI_BACKEND=mlx          # mlx | ollama | llamacpp | gemini-nano | harness

# Optional last-resort fallback, tried only if the primary backend fails. Leave empty for none.
HOOKS_AI_FALLBACK_BACKEND=''

# --- mlx (RECOMMENDED): a local MLX model via an OpenAI-compatible endpoint ---
# Served on this Mac by llama-swap / mlx_lm.server. The llama-swap model id == the weights path.
HOOKS_AI_ENDPOINT='http://127.0.0.1:8080/v1'
HOOKS_AI_MODEL="$HOME/qwen36-mlx"

# --- ollama: a LOCAL GENERATIVE model on :11434 (embedding-only models cannot generate) ---
HOOKS_AI_OLLAMA_MODEL='qwen3-coder:latest'

# --- llamacpp: fully offline llama-cli + a local GGUF ---
HOOKS_AI_GGUF=''

# --- gemini-nano: Chrome's built-in Gemini Nano via a Deno CDP driver (driver NOT shipped) ---
# Optional. Requires a recent Google Chrome + `deno` AND scripts/hooks/lib/gemini-nano.ts.
# CHROME_BIN overrides the Chrome binary; CHROME_CDP the DevTools endpoint (default :9222).
CHROME_BIN='/Applications/Google Chrome.app/Contents/MacOS/Google Chrome'

# --- harness: a frontier coding CLI (last resort; verify the headless/print flag for your install) ---
#   omc -p | claude -p | codex exec | omx exec | forge -p | opencode run
HOOKS_AI_HARNESS_CMD=''

# Generation knobs (shared)
HOOKS_AI_MAX_TOKENS=512
HOOKS_AI_TIMEOUT=90

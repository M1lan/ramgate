# Git-hook behaviour toggles (committed defaults). Sourced by scripts/hooks/*.bash.
# Override per-developer by editing this file, or per-invocation via the environment.
# No ANSI colour is ever emitted by the hooks -- output is plain text by house rule.

# Seconds to wait for an interactive answer before the hook ABORTS the git action.
# A non-answer is a soft nudge to improve the message/name, never a silent pass.
# The timeout exists only so a hook can never block I/O indefinitely.
HOOKS_TIMEOUT=4

# When a safety hook (secrets, large file, merge marker) trips, block the commit.
# Style hooks (commit-msg, branch-name, format) nudge interactively regardless.
HOOKS_BLOCKING=1

# Allow the optional LLM-assisted path (commit-message rewrite, format triage).
# Even when 1, AI NEVER fires on its own: it is always behind an explicit [a] choice,
# and requires `just hooks-ai-setup` to have configured a tool first.
HOOKS_LLM_ASSIST=1

# Conventional Commits types accepted by the commit-msg hook (space separated).
HOOKS_CC_TYPES="feat fix docs style refactor perf test build ci chore revert"

# Suggested ramgate scopes (advisory; the commit-msg hook prints these when it cannot
# infer a type). Any lowercase [a-z0-9._-] scope is accepted -- these are the canonical set.
HOOKS_CC_SCOPES="xray guard sample proc fmt config breaker ledger agent log docs harness"

# Branch-name prefixes accepted by the pre-push hook (space separated).
# Branches in HOOKS_BRANCH_PROTECTED are always allowed as-is.
HOOKS_BRANCH_TYPES="feat fix docs style refactor perf test build ci chore revert release hotfix"
HOOKS_BRANCH_PROTECTED="main master develop"

# Max subject length before the commit-msg hook warns (Conventional Commits guidance: 50-72).
HOOKS_SUBJECT_MAXLEN=72

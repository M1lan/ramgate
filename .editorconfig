root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 99

# The two extensionless binaries are Bash.
[{ram-xray,ram-guard}]
indent_style = space
indent_size = 2

[*.bash]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[{Justfile,*.just}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
